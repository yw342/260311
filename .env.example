# Supabase - 추첨 이력 저장용
# 로컬: 이 파일을 .env 로 복사 후 값 입력
# Vercel: Settings > Environment Variables 에서 동일한 이름으로 추가 (VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY)
# https://supabase.com 대시보드 > Settings > API 에서 URL/anon key 확인
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
